{
  "name": "@gvwilson/forma",
  "version": "0.7.0",
  "description": "Formative assessment widgets",
  "type": "module",
  "main": "./dist/forma.js",
  "exports": {
    ".": "./dist/forma.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "clean": "rm -rf dist",
    "serve": "node tests/server.js",
    "test": "npm run build && npx playwright test --config=playwright.config.js",
    "view": "npm info @gvwilson/forma"
  },
  "keywords": [
    "education",
    "widgets",
    "formative-assessment",
    "open-source"
  ],
  "author": "Greg Wilson",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.3"
  }
}
